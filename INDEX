function hasCWS(l) { return l.dakos.some(d => d.cws); }
function hasSab(l)  { return l.dakos.some(d => d.sab); }
function hasLin(l)  { return l.dakos.some(d => d.lin); }

function renderCards(filter = '') {
  const list = document.getElementById('lokalList');
  const noRes = document.getElementById('noResults');
  list.innerHTML = '';
  const q = filter.toLowerCase();

  let count = 0;
  data.forEach((lokal, i) => {
    const filteredDakos = q
      ? lokal.dakos.filter(d => d.name.toLowerCase().includes(q))
      : lokal.dakos;
    if (q && !lokal.lokal.toLowerCase().includes(q) && filteredDakos.length === 0) return;
    const showDakos = (q && filteredDakos.length > 0) ? filteredDakos : lokal.dakos;
    count++;

    const card = document.createElement('div');
    card.className = 'card' + (q ? ' open' : '');
    card.innerHTML = `
      <div class="card-header" onclick="toggle(this)">
        <span class="lokal-name">${lokal.lokal}</span>
        <div class="badge-row">
          ${hasSab(lokal) ? '<span class="badge sabado">Sabado</span>' : ''}
          ${hasLin(lokal) ? '<span class="badge linggo">Linggo</span>' : ''}
          ${hasCWS(lokal) ? '<span class="badge cws">CWS</span>' : ''}
        </div>
        <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
