        </svg>
      </div>
      <div class="card-body">
        <table class="dako-table">
          <thead>
            <tr>
              <th>Dako</th>
              <th>Sabado</th>
              <th>Linggo</th>
            </tr>
          </thead>
          <tbody>
            ${showDakos.map(d => `
              <tr>
                <td class="dako-name${d.cws ? ' is-cws' : ''}">${d.name}</td>
                <td>${d.sab ? `<span class="time-badge sab">${d.sab}</span>` : '<span class="dash">—</span>'}</td>
                <td>${d.lin ? `<span class="time-badge lin">${d.lin}</span>` : '<span class="dash">—</span>'}</td>
              </tr>`).join('')}
          </tbody>
        </table>
      </div>`;
    list.appendChild(card);
  });

  noRes.style.display = count === 0 ? 'block' : 'none';
}

function toggle(header) {
  const card = header.parentElement;
  card.classList.toggle('open');
}

