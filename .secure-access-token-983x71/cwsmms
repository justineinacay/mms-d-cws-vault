<html lang="fil">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CWS / PNK Schedule — Distrito ng Metro Manila South</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --blue:       #1A3A8F;
    --blue-dark:  #102460;
    --blue-mid:   #2952CC;
    --yellow:     #F5C518;
    --yellow-lt:  #FFF9D6;
    --green:      #1A7A45;
    --green-lt:   #D6F5E6;
    --red:        #C0392B;
    --red-lt:     #FDECEA;
    --bg:         #F0F4FF;
    --card:       #ffffff;
    --muted:      #7A84A8;
    --border:     rgba(26,58,143,0.12);
    --shadow:     0 4px 20px rgba(26,58,143,0.10);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    font-family: 'Poppins', sans-serif;
    color: var(--blue-dark);
    min-height: 100vh;
  }

  /* ── HEADER ── */
  header {
    background: var(--blue-dark);
    padding: 32px 20px 26px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  header::before {
    content: '';
    position: absolute;
    bottom: -80px; right: -80px;
    width: 300px; height: 300px;
    border-radius: 50%;
    background: rgba(245,197,24,0.08);
  }
  header::after {
    content: '';
    position: absolute;
    top: -60px; left: -60px;
    width: 200px; height: 200px;
    border-radius: 50%;
    background: rgba(245,197,24,0.06);
  }
  .header-tag {
    display: inline-block;
    background: var(--yellow);
    color: var(--blue-dark);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 12px;
  }
  header h1 {
    font-size: clamp(15px, 3.5vw, 22px);
    font-weight: 800;
    color: #fff;
    line-height: 1.35;
    max-width: 480px;
    margin: 0 auto 6px;
  }
  header p {
    font-size: 11px;
    color: rgba(255,255,255,0.5);
    letter-spacing: 1px;
    font-weight: 400;
  }

  /* ── LEGEND ── */
  .legend-bar {
    display: flex;
    justify-content: center;
    gap: 20px;
    padding: 14px 16px;
    background: var(--blue);
    flex-wrap: wrap;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 11px;
    font-weight: 600;
    color: rgba(255,255,255,0.9);
    letter-spacing: 0.3px;
  }
  .legend-dot {
    width: 12px; height: 12px;
    border-radius: 3px;
    flex-shrink: 0;
  }
  .legend-dot.tagalog { background: var(--green); }
  .legend-dot.english { background: var(--red); }

  /* ── SUMMARY PILLS ── */
  .summary-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    padding: 16px;
    background: #E8EEFF;
    border-bottom: 1px solid var(--border);
  }
  .pill {
    display: flex; flex-direction: column; align-items: center;
    background: var(--blue-dark);
    border-radius: 10px;
    padding: 10px 16px;
    min-width: 88px;
  }
  .pill .num {
    font-size: 22px;
    font-weight: 800;
    color: var(--yellow);
    line-height: 1;
  }
  .pill .desc {
    font-size: 8.5px;
    color: rgba(255,255,255,0.55);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    margin-top: 4px;
    text-align: center;
    max-width: 85px;
    font-weight: 500;
  }

  /* ── CONTROLS ── */
  .controls-wrap {
    max-width: 640px;
    margin: 0 auto;
    padding: 16px 16px 4px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .search-box {
    position: relative;
  }
  .search-box svg {
    position: absolute;
    left: 14px; top: 50%;
    transform: translateY(-50%);
    color: var(--muted);
    pointer-events: none;
  }
  .search-box input {
    width: 100%;
    padding: 11px 16px 11px 40px;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    background: white;
    font-family: 'Poppins', sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: var(--blue-dark);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .search-box input:focus {
    border-color: var(--yellow);
    box-shadow: 0 0 0 3px rgba(245,197,24,0.15);
  }
  .search-box input::placeholder { color: var(--muted); }

  /* ── FILTER TOGGLES ── */
  .filter-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .filter-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    border-radius: 8px;
    border: 1.5px solid var(--border);
    background: white;
    font-family: 'Poppins', sans-serif;
    font-size: 11.5px;
    font-weight: 600;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.18s;
    user-select: none;
  }
  .filter-btn .dot {
    width: 9px; height: 9px;
    border-radius: 2px;
    flex-shrink: 0;
  }
  .filter-btn:hover { border-color: var(--blue-mid); color: var(--blue); }

  .filter-btn.active-all   { background: var(--blue-dark); color: #fff; border-color: var(--blue-dark); }
  .filter-btn.active-tagalog { background: var(--green); color: #fff; border-color: var(--green); }
  .filter-btn.active-english { background: var(--red); color: #fff; border-color: var(--red); }
  .filter-btn.active-sabado  { background: var(--blue-mid); color: #fff; border-color: var(--blue-mid); }
  .filter-btn.active-linggo  { background: #6A3FBF; color: #fff; border-color: #6A3FBF; }

  /* ── LOKAL LIST ── */
  .lokal-list {
    max-width: 640px;
    margin: 0 auto;
    padding: 10px 16px 56px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  /* ── ACCORDION CARD ── */
  .card {
    background: var(--card);
    border-radius: 14px;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
    overflow: hidden;
    transition: box-shadow 0.2s;
  }
  .card.open { box-shadow: 0 8px 28px rgba(26,58,143,0.16); }

  .card-header {
    display: flex;
    align-items: center;
    padding: 15px 16px;
    cursor: pointer;
    user-select: none;
    gap: 10px;
  }
  .card-header:hover { background: rgba(26,58,143,0.03); }

  .lokal-name {
    font-size: 15px;
    font-weight: 700;
    color: var(--blue-dark);
    flex: 1;
  }
  .badge-row { display: flex; gap: 5px; align-items: center; flex-shrink: 0; flex-wrap: wrap; }
  .badge {
    font-size: 9.5px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 20px;
    letter-spacing: 0.4px;
  }
  .badge.sabado { background: #DCEAFF; color: var(--blue); }
  .badge.linggo  { background: #E8DCFF; color: #5B2DB0; }
  .badge.cws-badge { background: var(--red-lt); color: var(--red); }

  .chevron {
    width: 18px; height: 18px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
    color: var(--muted);
  }
  .card.open .chevron { transform: rotate(180deg); }

  /* ── TABLE ── */
  .card-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4,0,0.2,1);
  }
  .card.open .card-body { max-height: 700px; }

  .dako-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
  }
  .dako-table thead tr {
    background: var(--blue-dark);
  }
  .dako-table thead th {
    padding: 8px 14px;
    text-align: left;
    font-size: 9.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: rgba(255,255,255,0.6);
  }
  .dako-table thead th:not(:first-child) { text-align: center; }

  .dako-table tbody tr {
    border-top: 1px solid #EDF0F8;
    transition: background 0.12s;
  }
  .dako-table tbody tr:hover { background: rgba(26,58,143,0.03); }

  /* Row color coding */
  .dako-table tbody tr.row-tagalog {
    border-left: 4px solid var(--green);
  }
  .dako-table tbody tr.row-english {
    border-left: 4px solid var(--red);
  }

  .dako-table tbody td {
    padding: 9px 14px;
    vertical-align: middle;
  }

  .dako-name-cell {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .lang-pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 9px;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 20px;
    letter-spacing: 0.5px;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .lang-pill.tagalog {
    background: var(--green-lt);
    color: var(--green);
  }
  .lang-pill.english {
    background: var(--red-lt);
    color: var(--red);
  }
  .dako-name-text {
    font-size: 12px;
    font-weight: 500;
    color: var(--blue-dark);
  }

  .time-chip {
    display: inline-block;
    padding: 3px 9px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }
  .time-chip.sab { background: #DCEAFF; color: var(--blue); }
  .time-chip.lin { background: #E8DCFF; color: #5B2DB0; }
  .dash { color: #CCC; font-size: 13px; }

  td.center { text-align: center; }

  /* ── NO RESULTS ── */
  .no-results {
    text-align: center;
    padding: 48px 16px;
    color: var(--muted);
    font-size: 13px;
    display: none;
  }
  .no-results span { font-size: 28px; display: block; margin-bottom: 8px; }
</style>
</head>
