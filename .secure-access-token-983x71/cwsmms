let activeFilter = 'all';

function matchesFilter(d) {
  if (activeFilter === 'tagalog') return !d.cws;
  if (activeFilter === 'english') return !!d.cws;
  if (activeFilter === 'sabado')  return !!d.sab;
  if (activeFilter === 'linggo')  return !!d.lin;
  return true;
}

function hasCWS(l) { return l.dakos.some(d => d.cws); }
function hasSab(l)  { return l.dakos.some(d => d.sab); }
function hasLin(l)  { return l.dakos.some(d => d.lin); }

function renderCards() {
  const list    = document.getElementById('lokalList');
  const noRes   = document.getElementById('noResults');
  const q       = document.getElementById('search').value.trim().toLowerCase();
  list.innerHTML = '';
  let count = 0;

  data.forEach(lokal => {
    let dakos = lokal.dakos.filter(matchesFilter);
    if (q) {
      dakos = dakos.filter(d =>
        d.name.toLowerCase().includes(q) || lokal.lokal.toLowerCase().includes(q)
      );
      if (!lokal.lokal.toLowerCase().includes(q) && dakos.length === 0) return;
      if (lokal.lokal.toLowerCase().includes(q) && dakos.length === 0) {
        dakos = lokal.dakos.filter(matchesFilter);
      }
    }
    if (dakos.length === 0) return;
    count++;

    const isOpen = !!q;
    const card = document.createElement('div');
    card.className = 'card' + (isOpen ? ' open' : '');
    card.innerHTML = `
      <div class="card-header" onclick="toggleCard(this)">
        <span class="lokal-name">${lokal.lokal}</span>
        <div class="badge-row">
          ${hasSab(lokal) ? '<span class="badge sabado">Sabado</span>' : ''}
          ${hasLin(lokal) ? '<span class="badge linggo">Linggo</span>' : ''}
          ${hasCWS(lokal) ? '<span class="badge cws-badge">CWS</span>' : ''}
        </div>
        <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </div>
      <div class="card-body">
        <table class="dako-table">
          <thead>
            <tr>
              <th style="width:50%">Dako</th>
              <th>Sabado</th>
              <th>Linggo</th>
            </tr>
          </thead>
          <tbody>
            ${dakos.map(d => `
              <tr class="${d.cws ? 'row-english' : 'row-tagalog'}">
                <td>
                  <div class="dako-name-cell">
                    <span class="lang-pill ${d.cws ? 'english' : 'tagalog'}">${d.cws ? 'ENG' : 'FIL'}</span>
                    <span class="dako-name-text">${d.name}</span>
                  </div>
                </td>
                <td class="center">${d.sab ? `<span class="time-chip sab">${d.sab}</span>` : '<span class="dash">—</span>'}</td>
                <td class="center">${d.lin ? `<span class="time-chip lin">${d.lin}</span>` : '<span class="dash">—</span>'}</td>
              </tr>`).join('')}
          </tbody>
        </table>
      </div>`;
    list.appendChild(card);
  });

  noRes.style.display = count === 0 ? 'block' : 'none';
}

function toggleCard(header) {
  header.parentElement.classList.toggle('open');
}

// Filter buttons
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    activeFilter = btn.dataset.filter;
    document.querySelectorAll('.filter-btn').forEach(b => {
      b.className = 'filter-btn';
    });
    btn.classList.add('active-' + activeFilter);
    renderCards();
  });
});

document.getElementById('search').addEventListener('input', renderCards);

renderCards();
</script>
</body>
</html>
